
13.	Implement the C program for Disk Scheduling Algorithms: SSTF considering the initial head position moving away from the spindle.





#include<stdio.h>
#include<stdlib.h>

int main(){
    int r[20],n,h,i,j,min,d,t=0,pos;

    printf("Enter no. of requests: ");
    scanf("%d",&n);

    printf("Enter requests: ");
    for(i=0;i<n;i++)
        scanf("%d",&r[i]);

    printf("Enter head position: ");
    scanf("%d",&h);

    for(i=0;i<n;i++){
        min=9999;

        for(j=0;j<n;j++)
            if(r[j]!=-1){
                d=abs(h-r[j]);

                if(d<min){
                    min=d;
                    pos=j;
                }
            }

        t+=min;
        h=r[pos];

        printf("%d ",h);

        r[pos]=-1;
    }

    printf("\nTotal Seek Time = %d",t);

    return 0;
}
