
#include <stdio.h>

int main() {
    int n, i, t = 0, complete = 0, min;
    int at[10], bt[10], rt[10], wt[10], tat[10];
    float avgwt = 0, avgtat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("AT and BT of P%d: ", i + 1);
        scanf("%d%d", &at[i], &bt[i]);
        rt[i] = bt[i];
    }

    while(complete < n) {
        min = -1;

        for(i = 0; i < n; i++) {
            if(at[i] <= t && rt[i] > 0) {
                if(min == -1 || rt[i] < rt[min])
                    min = i;
            }
        }

        if(min == -1) {
            t++;
            continue;
        }

        rt[min]--;
        t++;

        if(rt[min] == 0) {
            complete++;
            tat[min] = t - at[min];
            wt[min] = tat[min] - bt[min];

            avgwt += wt[min];
            avgtat += tat[min];
        }
    }

    printf("\nP\tWT\tTAT\n");

    for(i = 0; i < n; i++)
        printf("P%d\t%d\t%d\n", i + 1, wt[i], tat[i]);

    printf("\nAverage WT = %.2f", avgwt / n);
    printf("\nAverage TAT = %.2f", avgtat / n);

    return 0;
}
