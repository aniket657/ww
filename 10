10.	Implement the C program for Page Replacement Algorithms: Optimal for frame size as minimum three.



#include<stdio.h>

int main(){
    int p[20],f[3]={-1,-1,-1},n,i,j,k,pf=0,pos,far,found;

    printf("Enter no. of pages: ");
    scanf("%d",&n);

    printf("Enter pages: ");
    for(i=0;i<n;i++)
        scanf("%d",&p[i]);

    for(i=0;i<n;i++){
        found=0;

        for(j=0;j<3;j++)
            if(f[j]==p[i])
                found=1;

        if(!found){
            pf++;

            for(j=0;j<3;j++)
                if(f[j]==-1){
                    f[j]=p[i];
                    goto print;
                }

            far=-1;

            for(j=0;j<3;j++){
                for(k=i+1;k<n;k++)
                    if(f[j]==p[k])
                        break;

                if(k>far){
                    far=k;
                    pos=j;
                }
            }

            f[pos]=p[i];
        }

        print:
        printf("\n%d\t%d\t%d",f[0],f[1],f[2]);
    }

    printf("\n\nPage Faults = %d",pf);

    return 0;
}
